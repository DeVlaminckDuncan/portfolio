{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "audit:accessibility": "bun run build && node scripts/accessibility-audit.mjs",
    "audit:performance": "bun run build && node scripts/performance-audit.mjs",
    "install:cross-browser": "playwright install chromium firefox webkit",
    "install:cross-browser:ci": "playwright install --with-deps chromium firefox webkit",
    "test:cross-browser": "bun run build && playwright test",
    "test:cross-browser:ci": "playwright test",
    "validate:structured-data": "node scripts/validate-json-ld.mjs",
    "check": "astro check",
    "check:ci": "biome ci . && astro check",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "^1.59.1",
    "chrome-launcher": "1.2.1",
    "lighthouse": "13.3.0",
    "typescript": "^6.0.3"
  }
}
