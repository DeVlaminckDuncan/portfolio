---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import Section from '../components/Section.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const visibleProjects = (await getCollection('projects', ({ data }) => data.draft !== true)).sort(
  (a, b) => a.data.order - b.data.order,
);

if (visibleProjects.length === 0) {
  throw new Error('Projects page requires at least one published project entry.');
}
---

<BaseLayout
  title="Projects | Duncan De Vlaminck"
  description="Selected portfolio project entries for Duncan De Vlaminck, covering ERP systems, mobile delivery, web interfaces, APIs, and AI-assisted workflows."
>
  <Section
    heading="Projects"
    headingLevel={1}
    description="Selected project entries covering ERP systems, mobile delivery, web interfaces, APIs, and AI-assisted workflows."
  >
    <div class="projects-grid">
      {
        visibleProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            techStack={project.data.techStack}
            headingLevel={2}
            href={`/projects/${project.id}/`}
          />
        ))
      }
    </div>
  </Section>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .projects-grid :global(.project-card) {
    min-height: 100%;
  }

  @media (max-width: 48rem) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
