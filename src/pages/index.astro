---
import Button from '../components/Button.astro';
import Section from '../components/Section.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const focusAreas = [
  {
    title: 'ERP systems',
    description:
      'ERP modules, integrations, planning flows, and process-heavy business tooling for service and project-based organizations.',
  },
  {
    title: 'FileMaker platforms',
    description:
      'Maintainable FileMaker apps with scripts, data models, web viewers, and HTML/CSS/JavaScript interfaces.',
  },
  {
    title: 'AI workflows',
    description:
      'OpenAI-powered workflows for email classification, invoice and order confirmation processing, and structured data extraction.',
  },
  {
    title: 'Agentic coding',
    description:
      'Development workflows using ChatGPT, Codex, and OpenCode for structured project setup, implementation, review, and verification.',
  },
];
---

<BaseLayout
  title="Duncan De Vlaminck | Software Engineering Portfolio"
  description="Software engineering portfolio focused on ERP systems, FileMaker platforms, web interfaces, AI workflows, and agentic coding."
>
  <Section
    heading="Duncan De Vlaminck"
    headingLevel={1}
    description="Software engineer building ERP systems, FileMaker platforms, web interfaces, AI workflows, and agentic coding processes."
    class="hero"
  >
    <p class="hero__pitch">
      I build business software across ERP systems, FileMaker platforms, and web
      interfaces, with a current focus on practical AI workflows and agentic
      coding processes that improve delivery and developer productivity.
    </p>

    <div class="hero__actions">
      <Button href="/projects/">View projects</Button>
    </div>
  </Section>

  <Section
    heading="Focus areas"
    description="Balanced engineering work across business systems, durable application platforms, and modern delivery workflows."
  >
    <div class="focus-grid">
      {
        focusAreas.map((area) => (
          <article class="focus-card">
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))
      }
    </div>
  </Section>
</BaseLayout>

<style>
  .hero__pitch {
    margin-block-end: var(--space-6);
    color: var(--color-text);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .focus-card {
    display: grid;
    align-content: start;
    gap: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    padding: var(--space-6);
  }

  .focus-card h3 {
    margin: 0;
    font-size: var(--font-size-xl);
  }

  .focus-card p {
    margin: 0;
  }

  @media (max-width: 48rem) {
    .focus-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
