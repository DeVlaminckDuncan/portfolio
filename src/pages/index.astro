---
import Button from '../components/Button.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Section from '../components/Section.astro';
import TextLink from '../components/TextLink.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Duncan De Vlaminck | Software Engineering Portfolio"
  description="A static-first software engineering portfolio built with Astro and TypeScript."
>
  <Section
    eyebrow="Software Engineering Portfolio"
    heading="Duncan De Vlaminck"
    headingLevel={1}
    description="This site is ready for future portfolio sections, projects, contact details, and deployment setup."
  >
    <div class="intro-actions">
      <Button href="/projects/">View projects</Button>
      <TextLink href="/about/">Read about the approach</TextLink>
    </div>
  </Section>

  <Section
    heading="Reusable component preview"
    description="A neutral preview of the shared UI primitives future portfolio pages can use."
  >
    <ProjectCard
      title="Project card component"
      description="A static-friendly card pattern for upcoming portfolio entries."
      techStack={['Astro', 'TypeScript', 'CSS']}
    />
  </Section>
</BaseLayout>

<style>
  .intro-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
  }
</style>
